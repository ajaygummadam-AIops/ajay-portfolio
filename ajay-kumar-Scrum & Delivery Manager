
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>G. Ajay Kumar — Scrum Master & Delivery Manager</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,900;1,400&family=Outfit:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<style>
/* =============================================
   DESIGN TOKENS
============================================= */
:root {
  --cream:      #F2EDE4;
  --cream-dark: #E8E0D4;
  --ink:        #1A1208;
  --ink-deep:   #0D0A04;
  --amber:      #C17A2A;
  --amber-lite: #E8A020;
  --amber-pale: rgba(193,122,42,0.12);
  --amber-glow: rgba(193,122,42,0.25);
  --teal:       #0ABFA3;
  --sky:        #4A9FE8;
  --dark-bg:    #111827;
  --dark-mid:   #0D1117;
  --dark-navy:  #0F1A2E;
  --dark-green: #0C1F1A;
  --dark-panel: #1A1208;
  --text-light: #F2EDE4;
  --text-muted: #8A9BB8;
  --text-dim:   #B8C6DC;
  --border-dark: rgba(255,255,255,0.07);
  --r: 10px;
  --r-sm: 4px;
}

/* =============================================
   RESET & BASE
============================================= */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body { font-family: 'Outfit', sans-serif; background: var(--dark-mid); color: var(--text-dim); overflow-x: hidden; line-height: 1.7; }
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: var(--dark-mid); }
::-webkit-scrollbar-thumb { background: var(--amber); border-radius: 2px; }

/* =============================================
   NAV
============================================= */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 900;
  height: 64px; display: flex; align-items: center; justify-content: space-between;
  padding: 0 5vw;
  background: rgba(10,8,4,0.92); backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(193,122,42,0.15);
  animation: slideDown 0.6s ease both;
}
@keyframes slideDown { from { transform: translateY(-100%); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

.nav-logo {
  font-family: 'Playfair Display', serif; font-size: 1.3rem; font-weight: 700;
  color: var(--amber); text-decoration: none; letter-spacing: 0.02em;
}
.nav-links { display: flex; gap: 28px; list-style: none; align-items: center; }
.nav-links a {
  color: var(--text-muted); font-size: 0.75rem; font-weight: 500;
  letter-spacing: 0.1em; text-transform: uppercase; text-decoration: none;
  position: relative; transition: color 0.2s;
}
.nav-links a::after {
  content: ''; position: absolute; bottom: -4px; left: 0; right: 0;
  height: 1px; background: var(--amber); transform: scaleX(0); transition: transform 0.25s;
}
.nav-links a:hover { color: var(--amber); }
.nav-links a:hover::after { transform: scaleX(1); }
.nav-cta {
  background: var(--amber); color: #fff; padding: 8px 22px;
  border-radius: var(--r-sm); font-size: 0.75rem; font-weight: 700;
  letter-spacing: 0.1em; text-transform: uppercase; text-decoration: none;
  border: 2px solid var(--amber); transition: all 0.2s;
}
.nav-cta:hover { background: transparent; color: var(--amber); }

/* =============================================
   HERO — SPLIT PANEL (reference layout)
============================================= */
#home {
  min-height: 100vh;
  display: grid;
  grid-template-columns: 1fr 1fr;
  padding-top: 64px;
}

/* Left — cream */
.hero-left {
  background: var(--cream);
  display: flex; flex-direction: column; justify-content: space-between;
  padding: 72px 6vw 52px;
}
.hero-eyebrow {
  display: flex; align-items: center; gap: 12px;
  font-family: 'JetBrains Mono', monospace; font-size: 0.65rem;
  letter-spacing: 0.2em; text-transform: uppercase; color: var(--amber);
  margin-bottom: 36px;
  animation: fadeUp 0.7s 0.1s ease both;
}
.hero-eyebrow::before { content: ''; width: 28px; height: 1px; background: var(--amber); }

h1.hero-name {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2.4rem, 4.5vw, 4rem);
  font-weight: 900; line-height: 1.05;
  color: var(--ink); letter-spacing: -0.02em;
  margin-bottom: 18px; white-space: nowrap;
  animation: fadeUp 0.7s 0.2s ease both;
}
.hero-tagline {
  font-size: 0.92rem; color: #6B5E50; margin-bottom: 24px;
  animation: fadeUp 0.7s 0.3s ease both;
}
.hero-tagline strong { color: var(--ink); font-weight: 600; }

.hero-desc {
  font-size: 0.9rem; color: #5A4E42; line-height: 1.85;
  max-width: 440px; margin-bottom: 36px;
  animation: fadeUp 0.7s 0.4s ease both;
}
.hero-btns {
  display: flex; gap: 14px; flex-wrap: wrap;
  animation: fadeUp 0.7s 0.5s ease both;
  margin-bottom: 0;
}
.btn-primary {
  background: var(--amber); color: #fff;
  padding: 13px 30px; border-radius: var(--r-sm);
  font-size: 0.78rem; font-weight: 700; letter-spacing: 0.12em;
  text-transform: uppercase; text-decoration: none;
  border: 2px solid var(--amber); transition: all 0.25s;
}
.btn-primary:hover { background: transparent; color: var(--amber); }
.btn-secondary {
  border: 1.5px solid var(--ink); color: var(--ink);
  padding: 13px 30px; border-radius: var(--r-sm);
  font-size: 0.78rem; font-weight: 600; letter-spacing: 0.12em;
  text-transform: uppercase; text-decoration: none;
  background: transparent; transition: all 0.25s;
}
.btn-secondary:hover { background: var(--ink); color: var(--cream); }

/* Stats row */
.hero-stats {
  display: flex; gap: 36px; padding-top: 40px;
  border-top: 1px solid #D4C8B8;
  animation: fadeUp 0.7s 0.6s ease both;
}
.hs-num {
  font-family: 'Playfair Display', serif;
  font-size: 1.9rem; font-weight: 700; color: var(--amber); line-height: 1;
}
.hs-lbl {
  font-size: 0.6rem; color: #8A7A6A;
  text-transform: uppercase; letter-spacing: 0.12em; margin-top: 4px;
}

/* Right — dark panel with role list */
.hero-right {
  background: var(--dark-panel);
  display: flex; flex-direction: column; justify-content: center;
  padding: 72px 5vw;
  position: relative; overflow: hidden;
}
.hero-right::before {
  content: ''; position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 60% 55% at 85% 25%, rgba(193,122,42,0.09) 0%, transparent 60%),
    radial-gradient(ellipse 40% 40% at 15% 75%, rgba(193,122,42,0.05) 0%, transparent 55%);
  pointer-events: none;
}
.hero-right-label {
  font-family: 'JetBrains Mono', monospace; font-size: 0.62rem;
  letter-spacing: 0.2em; text-transform: uppercase; color: #7A6A58;
  margin-bottom: 24px; position: relative; z-index: 1;
  animation: fadeUp 0.7s 0.3s ease both;
}
.role-list { display: flex; flex-direction: column; gap: 10px; position: relative; z-index: 1; }
.role-row {
  display: flex; align-items: center; gap: 16px;
  background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07);
  border-radius: 8px; padding: 17px 18px;
  transition: all 0.3s; cursor: default;
  animation: fadeUp 0.6s ease both;
}
.role-row:nth-child(1) { animation-delay: 0.35s; }
.role-row:nth-child(2) { animation-delay: 0.45s; }
.role-row:nth-child(3) { animation-delay: 0.55s; }
.role-row:nth-child(4) { animation-delay: 0.65s; }
.role-row:hover { background: rgba(193,122,42,0.08); border-color: rgba(193,122,42,0.4); transform: translateX(5px); }
.role-icon {
  width: 38px; height: 38px; border-radius: 8px;
  background: rgba(193,122,42,0.12); display: flex;
  align-items: center; justify-content: center;
  font-size: 1.1rem; flex-shrink: 0;
}
.role-body { flex: 1; }
.role-title { font-size: 0.92rem; font-weight: 700; color: var(--cream); margin-bottom: 3px; }
.role-desc { font-size: 0.7rem; color: #7A6A58; }
.role-badge {
  font-size: 0.6rem; font-weight: 700; letter-spacing: 0.1em;
  text-transform: uppercase; padding: 4px 11px; border-radius: 4px;
  flex-shrink: 0; white-space: nowrap;
}
.badge-amber { background: rgba(193,122,42,0.15); color: #E8A020; border: 1px solid rgba(193,122,42,0.4); }
.badge-active { background: rgba(10,191,163,0.12); color: var(--teal); border: 1px solid rgba(10,191,163,0.3); }
.badge-blue { background: rgba(74,159,232,0.12); color: var(--sky); border: 1px solid rgba(74,159,232,0.3); }

@keyframes fadeUp { from { opacity: 0; transform: translateY(18px); } to { opacity: 1; transform: translateY(0); } }

/* =============================================
   SECTION UTILITIES
============================================= */
.section-wrap { padding: 96px 5vw; }
.sec-eyebrow {
  display: flex; align-items: center; gap: 14px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.67rem; letter-spacing: 0.22em; text-transform: uppercase;
  margin-bottom: 14px;
}
.sec-eyebrow::before { content: ''; width: 28px; height: 1px; flex-shrink: 0; }
.eyebrow-amber { color: var(--amber); }
.eyebrow-amber::before { background: var(--amber); }
.eyebrow-teal { color: var(--teal); }
.eyebrow-teal::before { background: var(--teal); }
.eyebrow-sky { color: var(--sky); }
.eyebrow-sky::before { background: var(--sky); }

.sec-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2rem, 3.5vw, 2.8rem);
  font-weight: 700; line-height: 1.15; margin-bottom: 10px;
}
.title-light { color: var(--text-light); }
.title-dark  { color: var(--ink); }

.sec-sub { font-size: 0.9rem; line-height: 1.8; max-width: 540px; margin-bottom: 44px; }
.sub-light { color: var(--text-muted); }
.sub-dark  { color: #6B5E50; }

/* Reveal animation - subtle only, no hidden content */
.reveal { opacity: 1; transform: none; }
.reveal.animate-in { animation: fadeUp 0.7s ease both; }

/* =============================================
   EXPERIENCE  (#111827 dark slate)
============================================= */
#experience { background: #111827; }

.timeline { position: relative; max-width: 860px; }
.timeline::before {
  content: ''; position: absolute; left: 14px; top: 0; bottom: 0; width: 1px;
  background: linear-gradient(to bottom, var(--amber) 0%, rgba(193,122,42,0.15) 80%, transparent 100%);
}
.tl-item {
  display: grid; grid-template-columns: 44px 1fr;
  gap: 0 22px; margin-bottom: 52px;
}

.tl-dot-wrap { display: flex; flex-direction: column; align-items: center; padding-top: 3px; }
.tl-dot {
  width: 28px; height: 28px; border-radius: 50%; flex-shrink: 0;
  border: 2px solid var(--amber); background: #111827;
  display: flex; align-items: center; justify-content: center; z-index: 1;
}
.tl-dot.now {
  background: var(--amber); border-color: var(--amber);
  box-shadow: 0 0 0 6px rgba(193,122,42,0.18);
}
.tl-dot-inner { width: 8px; height: 8px; border-radius: 50%; background: var(--amber); }
.tl-dot.now .tl-dot-inner { background: var(--ink-deep); }

.tl-content {}
.tl-meta { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; margin-bottom: 8px; }
.tl-date {
  font-family: 'JetBrains Mono', monospace; font-size: 0.68rem;
  color: var(--amber); background: rgba(193,122,42,0.1);
  border: 1px solid rgba(193,122,42,0.25); padding: 3px 11px;
  border-radius: 20px; letter-spacing: 0.05em;
}
.tl-company { font-size: 0.76rem; color: var(--text-muted); }
.tl-role {
  font-family: 'Playfair Display', serif;
  font-size: 1.35rem; font-weight: 700;
  color: var(--text-light); margin-bottom: 14px; line-height: 1.2;
}
.tl-list { list-style: none; }
.tl-list li {
  font-size: 0.87rem; color: var(--text-dim);
  padding: 5px 0 5px 20px; position: relative;
  line-height: 1.72; border-bottom: 1px solid rgba(255,255,255,0.03);
}
.tl-list li:last-child { border-bottom: none; }
.tl-list li::before {
  content: ''; position: absolute; left: 0; top: 15px;
  width: 8px; height: 1px; background: var(--amber);
}
.tl-tags { display: flex; flex-wrap: wrap; gap: 7px; margin-top: 14px; }
.tl-tag {
  padding: 3px 12px; font-size: 0.67rem; font-weight: 500;
  border: 1px solid rgba(255,255,255,0.08); border-radius: 20px;
  color: var(--text-muted); background: rgba(255,255,255,0.03);
  transition: all 0.2s; letter-spacing: 0.04em;
}
.tl-tag:hover { border-color: rgba(193,122,42,0.4); color: var(--amber-lite); }

/* =============================================
   CERTIFICATIONS  (#0C1F1A deep teal-green)
============================================= */
#certifications { background: #0C1F1A; border-top: 1px solid rgba(10,191,163,0.1); border-bottom: 1px solid rgba(10,191,163,0.1); }

.certs-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); gap: 20px; }
.cert-card {
  background: rgba(10,191,163,0.05); border: 1px solid rgba(10,191,163,0.18);
  border-radius: var(--r); padding: 30px 22px; text-align: center;
  transition: all 0.3s; position: relative; overflow: hidden;
}
.cert-card::after {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
  background: linear-gradient(90deg, transparent, var(--teal), transparent);
  transform: scaleX(0); transition: transform 0.4s;
}
.cert-card:hover { border-color: rgba(10,191,163,0.5); transform: translateY(-5px); box-shadow: 0 18px 48px rgba(0,0,0,0.45); }
.cert-card:hover::after { transform: scaleX(1); }
.cert-icon { font-size: 2rem; margin-bottom: 14px; display: block; }
.cert-name {
  font-family: 'Playfair Display', serif; font-size: 1.05rem; font-weight: 700;
  color: var(--text-light); margin-bottom: 6px; line-height: 1.3;
}
.cert-issuer { font-size: 0.74rem; color: var(--text-muted); margin-bottom: 14px; }
.cert-badge {
  display: inline-block; padding: 4px 14px; border-radius: 20px;
  font-size: 0.64rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
  background: rgba(10,191,163,0.15); color: var(--teal); border: 1px solid rgba(10,191,163,0.35);
}

/* =============================================
   SKILLS  (#FAFAF8 clean white)
============================================= */
#skills { background: #FAFAF8; border-top: 1px solid #E8E4DC; border-bottom: 1px solid #E8E4DC; }

.sk-2col { display: grid; grid-template-columns: 1fr 1fr; gap: 0 80px; }
.sk-group { padding: 30px 0; border-bottom: 1px solid #E2DDD4; }
.sk-group:first-child, .sk-group:nth-child(2) { border-top: 1px solid #E2DDD4; }

.sk-title {
  font-family: 'Playfair Display', serif; font-size: 1.1rem; font-weight: 700;
  color: var(--ink); margin-bottom: 16px; display: flex; align-items: center; gap: 8px;
}
.sk-title::after {
  content: ''; flex: 1; height: 1.5px;
  background: linear-gradient(to right, var(--amber), transparent);
}
.sk-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--amber); flex-shrink: 0; }
.sk-pills { display: flex; flex-wrap: wrap; gap: 8px; }
.sk-pill {
  padding: 5px 15px; border: 1.5px solid #C8BEA8; border-radius: 4px;
  font-size: 0.76rem; color: #3D3020; background: #fff;
  transition: all 0.2s; cursor: default;
}
.sk-pill:hover { border-color: var(--amber); color: var(--amber); background: #FEF9F0; transform: translateY(-1px); }

@media (max-width: 680px) {
  .sk-2col { grid-template-columns: 1fr; }
  .sk-group:nth-child(2) { border-top: none; }
}

/* =============================================
   CHEAT SHEETS  (#F7F5F0)
============================================= */
#cheatsheets { background: #F7F5F0; border-top: 1px solid #E2DDD4; border-bottom: 1px solid #E2DDD4; }

.cs-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.cs-card {
  background: #fff; border: 1px solid #E2DDD4;
  border-radius: var(--r); overflow: hidden;
  display: flex; flex-direction: column; transition: all 0.3s;
}
.cs-card:hover { border-color: var(--amber); box-shadow: 0 8px 32px rgba(193,122,42,0.12); transform: translateY(-3px); }
.cs-head {
  background: #EEEBE4; padding: 18px 22px;
  display: flex; align-items: center; gap: 14px;
  border-bottom: 1px solid #E2DDD4;
}
.cs-icon {
  width: 40px; height: 40px; border-radius: 8px;
  display: flex; align-items: center; justify-content: center; font-size: 1.2rem; flex-shrink: 0;
}
.cs-icon.i-amber { background: rgba(193,122,42,0.15); }
.cs-icon.i-blue  { background: rgba(74,130,200,0.12); }
.cs-icon.i-teal  { background: rgba(10,175,155,0.12); }
.cs-icon.i-rose  { background: rgba(210,70,90,0.10);  }
.cs-head-title { font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 700; color: var(--ink); margin-bottom: 2px; }
.cs-head-sub { font-size: 0.68rem; color: #9A8E7E; font-family: 'JetBrains Mono', monospace; letter-spacing: 0.04em; }
.cs-body { padding: 18px 22px; flex: 1; }
.cs-list { list-style: none; }
.cs-list li {
  font-size: 0.8rem; color: #3D3428; padding: 6px 0 6px 16px;
  border-bottom: 1px solid #EEE; position: relative; line-height: 1.55;
}
.cs-list li:last-child { border-bottom: none; }
.cs-list li::before { content: '•'; position: absolute; left: 0; top: 6px; color: var(--amber); font-size: 1rem; line-height: 1.3; }
.cs-list strong { color: var(--ink); font-weight: 600; }

@media (max-width: 680px) { .cs-grid { grid-template-columns: 1fr; } }

/* =============================================
   THOUGHTS  (#0F1A2E deep navy)
============================================= */
#thoughts { background: #0F1A2E; border-top: 1px solid rgba(74,159,232,0.1); border-bottom: 1px solid rgba(74,159,232,0.1); }

.th-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(290px, 1fr)); gap: 20px; }
.th-card {
  background: rgba(255,255,255,0.03); border: 1px solid rgba(74,159,232,0.12);
  border-radius: var(--r); padding: 26px;
  transition: all 0.3s; position: relative; overflow: hidden;
}
.th-card::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
  background: linear-gradient(90deg, var(--amber), var(--sky));
  transform: scaleX(0); transform-origin: left; transition: transform 0.35s;
}
.th-card:hover { border-color: rgba(74,159,232,0.35); background: rgba(74,159,232,0.05); transform: translateY(-4px); box-shadow: 0 14px 44px rgba(0,0,0,0.35); }
.th-card:hover::before { transform: scaleX(1); }
.th-tags { display: flex; gap: 7px; flex-wrap: wrap; margin-bottom: 14px; }
.th-tag {
  font-size: 0.62rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase;
  padding: 3px 10px; border-radius: 20px;
  background: rgba(74,159,232,0.1); color: var(--sky); border: 1px solid rgba(74,159,232,0.25);
}
.th-tag.t-amber { background: rgba(193,122,42,0.1); color: var(--amber-lite); border-color: rgba(193,122,42,0.25); }
.th-title {
  font-family: 'Playfair Display', serif; font-size: 1.1rem; font-weight: 700;
  color: var(--text-light); margin-bottom: 10px; line-height: 1.3;
}
.th-body { font-size: 0.82rem; color: var(--text-muted); line-height: 1.75; margin-bottom: 18px; }
.th-author { display: flex; align-items: center; gap: 10px; }
.th-av {
  width: 30px; height: 30px; border-radius: 50%; background: var(--amber);
  color: var(--ink-deep); display: flex; align-items: center; justify-content: center;
  font-family: 'Playfair Display', serif; font-weight: 700; font-size: 0.82rem; flex-shrink: 0;
}
.th-byline { font-size: 0.7rem; color: var(--text-muted); }
.th-byline strong { color: var(--text-dim); font-weight: 500; }

/* =============================================
   ACHIEVEMENTS  (#0D1117)
============================================= */
#achievements { background: #0D1117; }

.ach-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(210px, 1fr)); gap: 18px; }
.ach-card {
  background: rgba(193,122,42,0.06); border: 1px solid rgba(193,122,42,0.2);
  border-radius: var(--r); padding: 36px 22px; text-align: center; transition: all 0.3s;
}
.ach-card:hover { border-color: var(--amber); transform: translateY(-5px); box-shadow: 0 18px 50px rgba(0,0,0,0.4); }
.ach-num {
  font-family: 'Playfair Display', serif; font-size: 3.2rem; font-weight: 900;
  color: var(--amber); line-height: 1; margin-bottom: 10px;
}
.ach-num sup { font-size: 1.8rem; }
.ach-text { font-size: 0.82rem; color: var(--text-dim); line-height: 1.6; }

/* =============================================
   EDUCATION  (#091522 deep navy)
============================================= */
#education { background: #091522; border-top: 1px solid rgba(74,159,232,0.08); }

.edu-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(270px, 1fr)); gap: 18px; }
.edu-card {
  background: rgba(74,159,232,0.05); border: 1px solid rgba(74,159,232,0.18);
  border-radius: var(--r); padding: 28px; display: flex; gap: 16px; align-items: flex-start;
  transition: all 0.3s;
}
.edu-card:hover { border-color: rgba(74,159,232,0.45); transform: translateY(-3px); }
.edu-icon { font-size: 2rem; flex-shrink: 0; }
